# WhatsApp Business Cloud API
# Get from: developers.facebook.com > App Dashboard > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_APP_SECRET=

# Trigger.dev
# Get from: cloud.trigger.dev > Project > API Keys
TRIGGERDEV_API_KEY=
TRIGGERDEV_API_URL=https://api.trigger.dev

# Anthropic (Claude API)
# Get from: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Cloudflare (for D1 HTTP API access from Trigger.dev)
# Get from: dash.cloudflare.com > Account > API Tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=
