# Telegram Bot API
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret

# Admin (your Telegram chat ID — get it by messaging @userinfobot)
ADMIN_CHAT_ID=

# Trigger.dev
# Get from: cloud.trigger.dev > Project > API Keys
TRIGGERDEV_API_KEY=
TRIGGERDEV_API_URL=https://api.trigger.dev

# Anthropic (Claude API)
# Get from: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Cloudflare (for D1 HTTP API access from Trigger.dev)
# Get from: dash.cloudflare.com > Account > API Tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=

# Telegram bot username (for deep link generation, without @)
TELEGRAM_BOT_USERNAME=
